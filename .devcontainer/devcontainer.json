{
  "name": "ghtun",
  "build": {
    "dockerfile": "./Dockerfile",
    "context": "."
  },
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": false
    }
  },
  "postStartCommand": "bash -lc '/app/startup.sh 2>&1 | tee /tmp/xray.log &'",
  "postAttachCommand": "bash -c 'echo \"\" && echo \"📋 Your VLESS link:\" && echo \"\" && grep \"vless://\" /tmp/xray.log || echo \"⏳ Xray is still starting, wait a moment and re-attach...\"'",
  "portsAttributes": {
    "8080": {
      "label": "xray-ws",
      "protocol": "http",
      "onAutoForward": "silent",
      "visibility": "public"
    }
  },
  "forwardPorts": [8080],
  "hostRequirements": {
    "cpus": 2
  }
}
